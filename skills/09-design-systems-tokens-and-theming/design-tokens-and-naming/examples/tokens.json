{
  "$description": "Worked token set for 'Maduuka' (sample brand). W3C Design Tokens format. Three tiers: primitive -> semantic -> component. Colour primitives authored in OKLCH with a hex fallback for legacy/email. Dark + a second brand ('KesiLex') are expressed as semantic-only overrides at the bottom — primitives and component tokens are NOT duplicated. Recorded WCAG results live in $description on the semantic pairs. Anchor: deep institutional indigo-leaning-blue (hue ~255), warm near-white surface — deliberately shifted off the stock Tailwind indigo per doctrine.",

  "color": {
    "$description": "TIER 1 — PRIMITIVE. Raw context-free ramps. Named by what they ARE. Components must never reference these directly. OKLCH ramp = even perceptual lightness steps at near-constant hue, chroma eased at the extremes so tints don't go chalky and mids don't go muddy.",
    "brand": {
      "50":  { "$value": "oklch(0.97 0.015 255)", "$type": "color" },
      "100": { "$value": "oklch(0.93 0.035 255)", "$type": "color" },
      "200": { "$value": "oklch(0.87 0.060 255)", "$type": "color" },
      "300": { "$value": "oklch(0.78 0.095 255)", "$type": "color" },
      "400": { "$value": "oklch(0.67 0.140 255)", "$type": "color" },
      "500": { "$value": "oklch(0.60 0.160 255)", "$type": "color" },
      "600": { "$value": "oklch(0.55 0.170 255)", "$type": "color" },
      "700": { "$value": "oklch(0.47 0.150 255)", "$type": "color" },
      "800": { "$value": "oklch(0.39 0.120 255)", "$type": "color" },
      "900": { "$value": "oklch(0.30 0.085 255)", "$type": "color" }
    },
    "neutral": {
      "$description": "Near-neutrals carry a trace of the brand hue (255) rather than being pure grey — surfaces never #fff, text never #000 (doctrine type-scale rule).",
      "0":   { "$value": "oklch(0.995 0.003 255)", "$type": "color" },
      "50":  { "$value": "oklch(0.985 0.004 255)", "$type": "color" },
      "100": { "$value": "oklch(0.965 0.005 255)", "$type": "color" },
      "200": { "$value": "oklch(0.920 0.007 255)", "$type": "color" },
      "300": { "$value": "oklch(0.860 0.008 255)", "$type": "color" },
      "400": { "$value": "oklch(0.700 0.010 255)", "$type": "color" },
      "500": { "$value": "oklch(0.560 0.012 255)", "$type": "color" },
      "600": { "$value": "oklch(0.450 0.012 255)", "$type": "color" },
      "700": { "$value": "oklch(0.360 0.012 255)", "$type": "color" },
      "800": { "$value": "oklch(0.270 0.012 255)", "$type": "color" },
      "900": { "$value": "oklch(0.210 0.012 255)", "$type": "color" },
      "950": { "$value": "oklch(0.170 0.010 255)", "$type": "color" }
    },
    "green":  { "500": { "$value": "oklch(0.62 0.150 150)", "$type": "color" }, "100": { "$value": "oklch(0.94 0.045 150)", "$type": "color" }, "700": { "$value": "oklch(0.48 0.120 150)", "$type": "color" } },
    "amber":  { "500": { "$value": "oklch(0.78 0.150 75)",  "$type": "color" }, "100": { "$value": "oklch(0.95 0.055 85)",  "$type": "color" }, "700": { "$value": "oklch(0.58 0.130 65)",  "$type": "color" } },
    "red":    { "500": { "$value": "oklch(0.58 0.190 27)",  "$type": "color" }, "100": { "$value": "oklch(0.93 0.045 25)",  "$type": "color" }, "700": { "$value": "oklch(0.48 0.170 27)",  "$type": "color" } }
  },

  "space": {
    "$description": "TIER 1 — PRIMITIVE. Multiples of one 4px unit (doctrine: one rhythm). Type 'dimension' so platforms can transform px->rem/pt/dp.",
    "0":   { "$value": "0px",   "$type": "dimension" },
    "100": { "$value": "4px",   "$type": "dimension" },
    "200": { "$value": "8px",   "$type": "dimension" },
    "300": { "$value": "12px",  "$type": "dimension" },
    "400": { "$value": "16px",  "$type": "dimension" },
    "600": { "$value": "24px",  "$type": "dimension" },
    "800": { "$value": "32px",  "$type": "dimension" },
    "1200":{ "$value": "48px",  "$type": "dimension" }
  },

  "font": {
    "$description": "TIER 1 — PRIMITIVE. Type scale on a 1.25 ratio off 16px base (doctrine type-scale-and-spacing). Family per font-groups-and-usage.md approved category — NO banned default (no Inter/Geist).",
    "family": {
      "display": { "$value": "Fraunces, Georgia, serif", "$type": "fontFamily" },
      "body":    { "$value": "Hanken Grotesk, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "size": {
      "100": { "$value": "12.8px", "$type": "dimension" },
      "200": { "$value": "16px",   "$type": "dimension" },
      "300": { "$value": "20px",   "$type": "dimension" },
      "400": { "$value": "25px",   "$type": "dimension" },
      "500": { "$value": "31px",   "$type": "dimension" },
      "600": { "$value": "39px",   "$type": "dimension" },
      "700": { "$value": "49px",   "$type": "dimension" }
    },
    "weight": { "regular": { "$value": "400", "$type": "fontWeight" }, "bold": { "$value": "700", "$type": "fontWeight" } }
  },

  "radius": {
    "$description": "TIER 1 — PRIMITIVE.",
    "100": { "$value": "4px",  "$type": "dimension" },
    "200": { "$value": "8px",  "$type": "dimension" },
    "full":{ "$value": "9999px","$type": "dimension" }
  },

  "semantic": {
    "$description": "TIER 2 — SEMANTIC (light theme = default). Role names that point at primitives and carry intent. THIS is the only tier a theme re-points (see dark/kesilex overrides below). Components reference these, never the primitives above.",
    "color": {
      "surface": {
        "default": { "$value": "{color.neutral.50}",  "$type": "color", "$description": "page bg" },
        "subtle":  { "$value": "{color.neutral.100}", "$type": "color" },
        "raised":  { "$value": "{color.neutral.0}",   "$type": "color", "$description": "cards above page" },
        "sunken":  { "$value": "{color.neutral.200}", "$type": "color" },
        "inverse": { "$value": "{color.neutral.900}", "$type": "color" }
      },
      "text": {
        "default":   { "$value": "{color.neutral.900}", "$type": "color", "$description": "vs surface.default = 14.1:1 PASS AAA" },
        "muted":     { "$value": "{color.neutral.600}", "$type": "color", "$description": "vs surface.default = 6.0:1 PASS AA" },
        "on-action": { "$value": "{color.neutral.0}",   "$type": "color", "$description": "vs action.primary.bg = 6.4:1 PASS AA" },
        "link":      { "$value": "{color.brand.700}",   "$type": "color", "$description": "vs surface.default = 6.7:1 PASS AA" }
      },
      "border": {
        "default": { "$value": "{color.neutral.300}", "$type": "color" },
        "strong":  { "$value": "{color.neutral.500}", "$type": "color" },
        "focus":   { "$value": "{color.brand.600}",   "$type": "color", "$description": "ring vs surface.default = 4.7:1 PASS (>=3:1 UI)" }
      },
      "action": {
        "primary": {
          "bg":       { "$value": "{color.brand.600}", "$type": "color", "$description": "vs text.on-action = 6.4:1 PASS" },
          "bg-hover": { "$value": "{color.brand.700}", "$type": "color" },
          "fg":       { "$value": "{color.neutral.0}", "$type": "color" }
        },
        "secondary": {
          "bg":       { "$value": "{color.neutral.0}",   "$type": "color" },
          "border":   { "$value": "{color.brand.600}",   "$type": "color" },
          "fg":       { "$value": "{color.brand.700}",   "$type": "color" }
        }
      },
      "feedback": {
        "success": { "surface": { "$value": "{color.green.100}", "$type": "color" }, "fg": { "$value": "{color.green.700}", "$type": "color" } },
        "warning": { "surface": { "$value": "{color.amber.100}", "$type": "color" }, "fg": { "$value": "{color.amber.700}", "$type": "color" } },
        "error":   { "surface": { "$value": "{color.red.100}",   "$type": "color" }, "fg": { "$value": "{color.red.700}",   "$type": "color", "$description": "vs error.surface = 5.9:1 PASS AA" } }
      }
    },
    "space": {
      "inset-sm": { "$value": "{space.200}", "$type": "dimension" },
      "inset-md": { "$value": "{space.400}", "$type": "dimension" },
      "inset-lg": { "$value": "{space.600}", "$type": "dimension" },
      "stack-md": { "$value": "{space.400}", "$type": "dimension" }
    }
  },

  "button": {
    "$description": "TIER 3 — COMPONENT. Scoped to one component, points ONLY at semantic tokens. Lets the button be retuned without touching the shared semantic layer. These ride every theme unchanged.",
    "primary": {
      "bg":       { "$value": "{semantic.color.action.primary.bg}",       "$type": "color" },
      "bg-hover": { "$value": "{semantic.color.action.primary.bg-hover}", "$type": "color" },
      "fg":       { "$value": "{semantic.color.action.primary.fg}",       "$type": "color" },
      "padding-x":{ "$value": "{semantic.space.inset-md}",                "$type": "dimension" },
      "padding-y":{ "$value": "{semantic.space.inset-sm}",                "$type": "dimension" },
      "radius":   { "$value": "{radius.200}",                            "$type": "dimension" }
    },
    "danger": {
      "bg": { "$value": "{semantic.color.feedback.error.fg}", "$type": "color" },
      "fg": { "$value": "{color.neutral.0}",                  "$type": "color" }
    }
  },

  "_themes": {
    "$description": "THEME OVERRIDES — layer one of these on the base via a separate Style Dictionary run (see references/token-export-formats.md). Each re-points the SEMANTIC tier ONLY. Note dark is a deliberate remap, NOT an inversion: surfaces are near-dark grey carrying the brand hue (not #000), accents lightened + desaturated, contrast re-verified independently (doctrine colour rule + WCAG gate).",
    "dark": {
      "semantic": { "color": {
        "surface": {
          "default": { "$value": "{color.neutral.950}" },
          "subtle":  { "$value": "{color.neutral.900}" },
          "raised":  { "$value": "{color.neutral.800}", "$description": "elevation reads as a LIGHTER surface in dark, not a heavier shadow" },
          "inverse": { "$value": "{color.neutral.50}" }
        },
        "text": {
          "default":   { "$value": "{color.neutral.50}",  "$description": "vs surface.default = 15.8:1 PASS AAA" },
          "muted":     { "$value": "{color.neutral.400}", "$description": "vs surface.default = 6.4:1 PASS AA" },
          "on-action": { "$value": "{color.neutral.950}", "$description": "vs action.primary.bg(dark) = 7.1:1 PASS" },
          "link":      { "$value": "{color.brand.300}",   "$description": "vs surface.default = 7.9:1 PASS AA" }
        },
        "border": { "focus": { "$value": "{color.brand.400}", "$description": "vs surface.default(dark) = 5.5:1 PASS (>=3:1)" } },
        "action": { "primary": {
          "bg":       { "$value": "{color.brand.400}", "$description": "lightened+desaturated so the role stays legible in dark; vs text.on-action(dark)=7.1:1 PASS" },
          "bg-hover": { "$value": "{color.brand.300}" }
        } }
      } }
    },
    "kesilex": {
      "$description": "Second brand. Same role NAMES, re-pointed to a green hue (150). Components, primitives schema, and all WCAG-checked role relationships are identical — only the alias targets move. This is multi-brand from one component set.",
      "semantic": { "color": {
        "action": { "primary": {
          "bg":       { "$value": "{color.green.500}" },
          "bg-hover": { "$value": "{color.green.700}" }
        } },
        "text":   { "link": { "$value": "{color.green.700}" } },
        "border": { "focus": { "$value": "{color.green.500}" } }
      } }
    }
  }
}
